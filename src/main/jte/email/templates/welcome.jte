@param String username

<!doctype html>
<html lang="en">
<body>
<p>Welcome to <strong>Mini Ecommerce</strong>, <strong>${username}</strong>!</p>
<p>Thanks for signing up to keep in touch with <strong>Mini Ecommerce</strong>. From now on, you will receive regular updates on orders, discounts and special offers.</p>
<p>We are so pleased to have you.</p>
</body>
</html>